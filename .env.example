# Configuration publique intégrée à l'application Expo.
# La clé anon Supabase est destinée au client ; la sécurité des données doit
# être assurée par les politiques RLS configurées dans Supabase.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Ancien module Bible uniquement. Ne place jamais une clé réellement secrète
# dans une variable EXPO_PUBLIC_* : elle serait incluse dans l'application.
BIBLE_API_KEY=your-bible-api-key
